# ============================================================================
# Google Ads Agent — environment template
# Copy to apps/web/.env.local and fill in. NEVER commit the filled-in file.
# ============================================================================

# --- Supabase (Postgres + Storage) -----------------------------------------
# From your Supabase project: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service-role key is SERVER-ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- LLM provider (provider-abstracted; default = Gemini for MVP) -----------
# Which provider the abstraction uses: "gemini" | "anthropic" | "openai"
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
# Gemini (Google AI Studio): https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key
# Optional alternates (only needed if LLM_PROVIDER is set to them)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Google Ads API (MVP = TEST account only) ------------------------------
# Developer token with TEST access (immediate). Production access is out of MVP scope.
# See docs/GOOGLE_ADS_SETUP.md. login-customer-id may include dashes (stripped in code).
# NEVER put real values here — this file is committed. Put them in apps/web/.env.local.
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
# Set to "true" to force the mock Google Ads client even when creds are present.
GOOGLE_ADS_USE_MOCK=false


# --- Stock images (Module 3 rendering; free tiers) -------------------------
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=

# --- AI background images (Module 4 rendering; optional, OFF by default) -----
# Generates a bespoke, on-brand backdrop per creative; text/logo/CTA are still
# composited deterministically on top (the model never makes the finished ad).
# "none" (default) keeps stock-photo / brand-gradient behavior with no API spend.
# Set to "gemini" (reuses GEMINI_API_KEY above) to enable. Generated images are
# cached in the Supabase Storage bucket below (generate-once per unique brief), so
# create a PRIVATE bucket with this name in your Supabase project first.
IMAGE_GEN_PROVIDER=none
IMAGE_GEN_MODEL=imagen-3.0-generate-002
IMAGE_GEN_BUCKET=generated-creatives

# --- Python AI service (Module 2 analysis, Module 3 generation) -------------
# Run it from services/ai: `uv run uvicorn gaa_ai.api:app --port 8000`
AI_SERVICE_URL=http://localhost:8000

# --- App ---------------------------------------------------------------------
NODE_ENV=development
